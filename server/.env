# MongoDB Atlas connection string
# Get your connection string from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Example: MONGODB_URI="mongodb+srv://user123:pass@cluster0.abcd.mongodb.net/academic-dashboard?retryWrites=true&w=majority"
# MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/academic-dashboard?retryWrites=true&w=majority

# Server port
PORT=5001
